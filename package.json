{
  "name": "@clawsense/clawsense",
  "version": "0.1.0",
  "private": true,
  "description": "ClawSense plugin for OpenClaw",
  "homepage": "https://github.com/cedricxie366-stack/ClawSense",
  "bugs": {
    "url": "https://github.com/cedricxie366-stack/ClawSense/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cedricxie366-stack/ClawSense.git"
  },
  "type": "module",
  "files": [
    "README.md",
    "index.ts",
    "install.sh",
    "openclaw.plugin.json",
    "src/**/*.ts",
    "tsconfig.json"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{ recursive:true, force:true })\" && tsc -p tsconfig.json",
    "check": "npm run build",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "@sinclair/typebox": "0.34.48",
    "openai": "^6.25.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
