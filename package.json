{
  "name": "clawsense-openclaw-plugin",
  "version": "0.1.0",
  "private": false,
  "description": "Always-on sensory companion plugin for OpenClaw",
  "homepage": "https://github.com/cedricxie366-stack/ClawSense",
  "bugs": {
    "url": "https://github.com/cedricxie366-stack/ClawSense/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cedricxie366-stack/ClawSense.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "README.md",
    "LICENSE",
    "install.sh",
    "dist/**/*.js",
    "openclaw.plugin.json",
    "package.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{ recursive:true, force:true })\" && tsc -p tsconfig.json",
    "check": "npm run build",
    "test": "vitest run --config vitest.config.ts",
    "prepack": "npm run check && npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "@sinclair/typebox": "0.34.48",
    "openai": "^6.25.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
